PORT=3000
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
REDIS_URL=redis://localhost:6379

# Comma-separated list of browser origins allowed to call the API via CORS
# (e.g. https://app.blinkugc.com,https://blinkugc.com). Native iOS/curl
# requests send no Origin header and are always allowed. If unset, all
# origins are allowed (fine for local dev, NOT recommended in production).
ALLOWED_ORIGINS=
# fal.ai API key (format: <id>:<secret>) — used for UGC TTS + lip-sync
FAL_KEY=

# Razorpay payment integration (India). KEY_ID is also exposed to the
# browser inside the /api/credits/checkout response. SECRET is server-
# only. WEBHOOK_SECRET is set in the Razorpay dashboard when you
# register the webhook URL (POST https://your-api/api/webhooks/razorpay).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional shared secret for the admin grant endpoint
# (POST /api/credits/admin/grant). Leave unset to disable.
ADMIN_API_TOKEN=

# Optional: direct Postgres URL (Settings → Database in Supabase). Used
# only by `npm run migrate:*` scripts. If unset, you can paste the SQL
# from backend/migrations/009_credits.sql into the Supabase SQL editor.
# DATABASE_URL=postgres://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

