{
  "name": "gumby-ai-backend",
  "version": "1.0.0",
  "description": "Blinkugc backend server",
  "main": "src/index.js",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate:ugc": "node scripts/apply-migration.js migrations/002_ugc.sql",
    "migrate:ugc-creator-jobs": "node scripts/apply-migration.js migrations/004_ugc_creator_jobs.sql",
    "migrate:nullable-template": "node scripts/apply-migration.js migrations/007_nullable_template_id.sql",
    "migrate:credits": "node scripts/apply-migration.js migrations/009_credits.sql",
    "migrate:credits-usd": "node scripts/apply-migration.js migrations/010_credits_usd.sql",
    "migrate:top-templates": "node scripts/apply-migration.js migrations/011_top_templates.sql",
    "migrate:top-template-wardrobe": "node scripts/apply-migration.js migrations/013_top_template_wardrobe.sql",
    "seed:templates:urls": "node scripts/seed-templates-from-urls.js",
