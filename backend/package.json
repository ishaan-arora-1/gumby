    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "ffmpeg-static": "^5.3.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "openai": "^6.35.0",
    "pg": "^8.20.0",
    "razorpay": "^2.9.6",
    "redis": "^4.7.0",
    "uuid": "^10.0.0"
  },
